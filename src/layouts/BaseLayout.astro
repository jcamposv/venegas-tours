---
import { siteConfig, booking, footer } from "../data/site";
import BookingModal from "../components/booking/BookingModal";
import "../styles/global.css";

interface Props { title?: string; description?: string; }
const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
const ogImage = `${siteConfig.url}/logo.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Costa Rica tours, Guanacaste tours, volcano tours, beach tours, birdwatching Costa Rica, La Leona waterfall, Arenal volcano, Rio Celeste, sunset tours, crocodile tour Tarcoles, catamaran Costa Rica, Conchal beach, Flamingo beach, Tamarindo, adventure tours, family tours Costa Rica, private tours Costa Rica" />
    <meta name="author" content={siteConfig.name} />
    <link rel="canonical" href={siteConfig.url} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="CR-G" />
    <meta name="geo.placename" content="Guanacaste, Costa Rica" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteConfig.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "TouristAttraction",
      "additionalType": "LocalBusiness",
      "name": siteConfig.name,
      "description": siteConfig.description,
      "url": siteConfig.url,
      "logo": ogImage,
      "image": ogImage,
      "telephone": [footer.contact.phone, footer.contact.phone2],
      "email": footer.contact.email,
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Guanacaste",
        "addressCountry": "CR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "10.4157",
        "longitude": "-85.7520"
      },
      "openingHours": "Mo-Su 07:00-20:00",
      "priceRange": "$75 - $450 USD",
      "sameAs": [
        "https://www.instagram.com/venegas.olger",
        "https://www.facebook.com/share/1Edss9RNcn/",
        "https://www.tiktok.com/@olgervenegas"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Costa Rica Tours",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "La Leona Waterfall Tour", "description": "Hike through tropical forest trails to stunning turquoise waters" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Arenal Volcano Adventure", "description": "Full day tour to Arenal National Park with hot springs" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Rio Celeste Tour", "description": "Discover the mystical turquoise river of Tenorio National Park" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Birdwatching Tour", "description": "Early morning birdwatching in Santa Rosa National Park" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Tárcoles River Crocodile Tour", "description": "Boat safari with up-close crocodile encounters" } },
          { "@type": "Offer", "itemOffered": { "@type": "TouristTrip", "name": "Sunset Beach Tour", "description": "Visit Guanacaste's best beaches with Pacific sunset" } }
        ]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "300",
        "bestRating": "5"
      }
    })} />
  </head>
  <body class="min-h-screen">
    <slot />
    <BookingModal client:load whatsappNumber={booking.whatsapp.number} whatsappNumber2={booking.whatsapp.number2} googleCalendarEnabled={booking.googleCalendar.enabled} clinicName={siteConfig.name} clinicAddress={footer.contact.address.replace("\n", ", ")} />

    <script>
      document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const bookingBtn = target.closest("[data-booking]");
        if (bookingBtn) { e.preventDefault(); window.dispatchEvent(new CustomEvent("open-booking")); return; }
        const link = target.closest('a[href="#top"]') as HTMLAnchorElement | null;
        if (link) { e.preventDefault(); window.scrollTo({ top: 0, behavior: "smooth" }); }
      });

      const obs = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) e.target.classList.add("visible"); });
      }, { threshold: 0.1 });
      document.querySelectorAll("[data-animate]").forEach((el) => obs.observe(el));
    </script>
  </body>
</html>
