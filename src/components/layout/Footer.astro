---
import { siteConfig, footer } from "../../data/site";
---

<footer class="bg-charcoal text-white/70">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-10">
      <!-- Brand - spans 2 cols on desktop -->
      <div class="col-span-2">
        <img src="/logo-white.png" alt={siteConfig.name} class="h-20 mb-4" />
        <p class="text-white/50 text-sm leading-relaxed max-w-xs font-body">
          Authentic Costa Rica experiences since 2010. Family owned, locally guided.
        </p>
        <div class="flex gap-4 mt-6">
          {footer.socials.map((s) => (
            <a href={s.href} class="text-white/40 hover:text-sun transition-colors text-sm">{s.label}</a>
          ))}
        </div>
      </div>

      <div>
        <h3 class="font-semibold text-xs uppercase tracking-wider text-sun mb-4">Tours</h3>
        <ul class="space-y-2.5 text-sm">
          {footer.tours.map((t) => (<li><a href="#tours" class="hover:text-white transition-colors">{t}</a></li>))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-xs uppercase tracking-wider text-sun mb-4">Beaches</h3>
        <ul class="space-y-2.5 text-sm">
          {footer.beaches.map((b) => (<li><a href="#beaches" class="hover:text-white transition-colors">{b}</a></li>))}
        </ul>
      </div>

      <div>
        <h3 class="font-semibold text-xs uppercase tracking-wider text-sun mb-4">Contact</h3>
        <address class="not-italic space-y-2.5 text-sm">
          <p class="whitespace-pre-line">{footer.contact.address}</p>
          <p><a href={`tel:${footer.contact.phone.replace(/\D/g, "")}`} class="hover:text-white transition-colors">{footer.contact.phone}</a></p>
          <p><a href={`mailto:${footer.contact.email}`} class="hover:text-white transition-colors">{footer.contact.email}</a></p>
          <p class="text-white/40 text-xs">{footer.hours}</p>
        </address>
      </div>
    </div>

    <!-- Payment methods -->
    <div class="mt-14 pt-8 border-t border-white/10">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-white/30 text-sm">&copy; {new Date().getFullYear()} {siteConfig.name}. All rights reserved.</p>
        <div class="flex items-center gap-3">
          <span class="text-white/30 text-xs mr-1">We accept</span>
          <!-- Visa -->
          <svg class="h-8" viewBox="0 0 780 500" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="780" height="500" rx="40" fill="#1A1F71"/>
            <path d="M293.2 348.7l33.4-206.7h53.4l-33.4 206.7H293.2zM540.7 146.5c-10.6-4.2-27.2-8.6-47.9-8.6-52.8 0-90 28.1-90.2 68.3-.3 29.7 26.5 46.3 46.8 56.2 20.8 10.1 27.8 16.6 27.7 25.7-.1 13.9-16.6 20.2-32 20.2-21.4 0-32.7-3.1-50.3-10.8l-6.9-3.3-7.5 46.4c12.5 5.8 35.6 10.8 59.6 11 56.2 0 92.6-27.7 93-70.5.2-23.5-14-41.4-44.8-56.2-18.6-9.6-30.1-15.9-30-25.6 0-8.6 9.7-17.7 30.6-17.7 17.5-.3 30.1 3.7 40 7.9l4.8 2.4 7.1-45.4zM651.1 142h-41.3c-12.8 0-22.4 3.7-28 17.1L490 348.7h56.2l11.2-31h68.7l6.5 31h49.6L651.1 142zm-66.2 133.3c4.4-12 21.5-58.2 21.5-58.2-.3.5 4.4-12.1 7.2-19.9l3.6 18s10.4 50 12.5 60.1h-44.8zM246.2 142l-52.4 140.8-5.6-28.8c-9.7-33-40-68.8-73.9-86.7l47.9 181.2h56.6L302.8 142h-56.6z" fill="white"/>
            <path d="M147.8 142H60.6l-.6 3.6c67.1 17.2 111.5 58.6 130 108.4L171.1 159c-3.2-13-12.6-16.6-23.3-17z" fill="#F9A533"/>
          </svg>
          <!-- Mastercard -->
          <svg class="h-8" viewBox="0 0 780 500" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="780" height="500" rx="40" fill="#16366F"/>
            <circle cx="312" cy="250" r="148" fill="#D9222A"/>
            <circle cx="468" cy="250" r="148" fill="#EE9F2D"/>
            <path d="M390 130.7c-36.5 29.4-59.8 74.5-59.8 125.3s23.3 95.9 59.8 125.3c36.5-29.4 59.8-74.5 59.8-125.3s-23.3-95.9-59.8-125.3z" fill="#EB6100"/>
          </svg>
          <!-- PayPal -->
          <img src="/paypal.png" alt="PayPal" class="h-8 rounded" />
        </div>
      </div>
      <p class="text-white/30 text-xs italic text-center sm:text-right mt-3">Pura Vida 🌴</p>
    </div>
  </div>
</footer>
