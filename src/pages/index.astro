---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import HeroSection from "../components/sections/HeroSection.astro";
import ToursSection from "../components/sections/ToursSection.astro";
import BeachesSection from "../components/sections/BeachesSection.astro";
import ExperiencesSection from "../components/sections/ExperiencesSection.astro";
import AboutSection from "../components/sections/AboutSection.astro";
import WhyUsSection from "../components/sections/WhyUsSection.astro";
import TestimonialsSection from "../components/sections/TestimonialsSection.astro";
import CTASection from "../components/sections/CTASection.astro";
---

<BaseLayout>
  <Header />
  <main>
    <HeroSection />
    <ToursSection />
    <BeachesSection />
    <ExperiencesSection />
    <AboutSection />
    <WhyUsSection />
    <TestimonialsSection />
    <CTASection />
  </main>
  <Footer />
</BaseLayout>
