---
import { hero } from "../../data/site";
---

<section class="relative min-h-[85vh] lg:min-h-[95vh] overflow-hidden pt-24 lg:pt-28 pb-20 lg:pb-0">
  <!-- Background image -->
  <div class="absolute inset-0 -z-10">
    <img src={hero.image} alt="Costa Rica landscape" class="w-full h-full object-cover object-[50%_30%] lg:object-[50%_75%] hero-img" loading="eager" />
    <div class="absolute inset-0 bg-gradient-to-b from-charcoal/40 via-charcoal/20 to-charcoal/60"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-full">
    <div class="max-w-3xl">
      <!-- Badge -->
      <div class="hero-fade-in inline-flex items-center gap-2 bg-white/95 backdrop-blur text-jungle text-xs font-semibold px-4 py-1.5 rounded-full mb-6" style="--delay: 0.1s">
        <span class="w-1.5 h-1.5 bg-sun rounded-full animate-pulse"></span>
        {hero.badge}
      </div>

      <h1 class="hero-fade-in text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-extrabold text-white tracking-tight leading-[1.05]" style="--delay: 0.3s">
        {hero.headline.line1}<br />
        <span class="italic font-medium text-sun">{hero.headline.accent}</span>{" "}
        {hero.headline.line2}
      </h1>

      <p class="hero-fade-in mt-6 text-white/80 text-lg lg:text-xl font-body leading-relaxed max-w-xl" style="--delay: 0.5s">
        {hero.description}
      </p>

      <div class="hero-fade-in mt-10 flex flex-col sm:flex-row gap-4" style="--delay: 0.7s">
        <button data-booking class="inline-flex items-center justify-center gap-2 bg-sun hover:bg-sun-dark text-charcoal font-bold rounded-full px-8 py-4 text-base transition-all shadow-lg shadow-black/20 cursor-pointer">
          {hero.cta.primary}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </button>
        <a href="#tours" class="inline-flex items-center justify-center gap-2 bg-white/10 backdrop-blur border-2 border-white/30 hover:bg-white hover:text-charcoal text-white font-semibold rounded-full px-8 py-4 text-base transition-all">
          {hero.cta.secondary}
        </a>
      </div>

      <!-- Stats -->
      <div class="hero-fade-in mt-14 grid grid-cols-2 sm:grid-cols-4 gap-6 max-w-2xl" style="--delay: 0.9s">
        {hero.stats.map((s) => (
          <div>
            <span class="block text-2xl lg:text-3xl font-extrabold text-white">{s.value}</span>
            <span class="text-white/60 text-xs uppercase tracking-wider mt-1 block">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes heroFadeIn {
    from {
      opacity: 0;
      transform: translateY(24px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroImgScale {
    from {
      transform: scale(1.08);
    }
    to {
      transform: scale(1);
    }
  }

  .hero-fade-in {
    opacity: 0;
    animation: heroFadeIn 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--delay, 0s);
  }

  .hero-img {
    animation: heroImgScale 1.4s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade-in,
    .hero-img {
      animation: none;
      opacity: 1;
    }
  }
</style>
